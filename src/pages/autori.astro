// src/pages/autori.astro
import { getCollection } from 'astro:content';

const tuttiRacconti = await getCollection('racconti', ({ data }) => !data.isDraft);

// FIX #5 — leggi anche la collection autori per includere autori senza racconti
const autoriCollection = await getCollection('autori', ({ data }) => !data.isDraft);



// ─── HELPERS ────────────────────────────────────────────────────────────────
function slugify(name: string): string {
  return name
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

// ─── METADATI STATICI AUTORI ──────────────────────────────────────────────
const AUTHOR_META: Record<string, { kanji: string; anni: string; temi: string; foto: string }> = {
  'Osamu Dazai':           { kanji: '太宰治',       anni: '1909–1948', temi: 'alienazione · ironia tragica · autodistruzione',  foto: '' },
  'Ryūnosuke Akutagawa':   { kanji: '芥川龍之介',   anni: '1892–1927', temi: 'folklore · psicologia · ambiguità morale',         foto: '' },
  'Yasunari Kawabata':     { kanji: '川端康成',     anni: '1899–1972', temi: 'malinconia · bellezza transitoria · solitudine',   foto: '' },
  "Jun'ichirō Tanizaki":   { kanji: '谷崎潤一郎',   anni: '1886–1965', temi: 'ossessione · estetica · sensualità oscura',        foto: '' },
  'Natsume Soseki':        { kanji: '夏目漱石',     anni: '1867–1916', temi: 'identità · modernità · isolamento interiore',      foto: '' },
  'Lafcadio Hearn':        { kanji: '小泉八雲',     anni: '1850–1904', temi: 'fantasmi · folklore · meraviglia notturna',        foto: '' },
  'Edogawa Ranpo':         { kanji: '江戸川乱歩',   anni: '1894–1965', temi: 'giallo · ossessione · grotesco',                   foto: '' },
  'Yukio Mishima':         { kanji: '三島由紀夫',   anni: '1925–1970', temi: 'bellezza · morte · tradizione infranta',           foto: '' },
  'Izumi Kyoka':           { kanji: '泉鏡花',       anni: '1873–1939', temi: 'soprannaturale · romanticismo · eros',             foto: '' },
  'Doppo Kunikida':        { kanji: '国木田独歩',   anni: '1871–1908', temi: 'naturalismo · solitudine · natura aspra',          foto: '' },
  'Toson Shimazaki':       { kanji: '島崎藤村',     anni: '1872–1943', temi: 'naturalismo · famiglia · transizione epocale',    foto: '' },
  'Koyo Ozaki':            { kanji: '尾崎紅葉',     anni: '1867–1903', temi: "amore · melodramma · fine di un'epoca",            foto: '' },
  'Saisei Muro':           { kanji: '室生犀星',     anni: '1889–1962', temi: 'lirismo · infanzia · malinconia',                  foto: '' },
  'Kan Kikuchi':           { kanji: '菊池寛',       anni: '1888–1948', temi: 'dramma · ironia · società borghese',               foto: '' },
  'Kafu Nagai':            { kanji: '永井荷風',     anni: '1879–1959', temi: 'nostalgia · erotismo · Tokyo perduta',             foto: '' },
  'Mori Ogai':             { kanji: '森鷗外',       anni: '1862–1922', temi: 'dualismo · storia · dovere e libertà',             foto: '' },
  'Ango Sakaguchi':        { kanji: '坂口安吾',     anni: '1906–1955', temi: 'decadenza · nichilismo · post-guerra',             foto: '' },
  'Fumiko Hayashi':        { kanji: '林芙美子',     anni: '1903–1951', temi: 'vagabondaggio · femminile · povertà dignitosa',    foto: '' },
  'Naoya Shiga':           { kanji: '志賀直哉',     anni: '1883–1971', temi: 'introspezione · natura · autobiografia',           foto: '' },
  'Saneatsu Mushanokoji':  { kanji: '武者小路実篤',  anni: '1885–1976', temi: 'umanesimo · ideale · comunità',                   foto: '' },
  'Riichi Yokomitsu':      { kanji: '横光利一',     anni: '1898–1947', temi: 'sensazionismo · modernismo · velocità',            foto: '' },
  'Mokichi Saito':         { kanji: '斎藤茂吉',     anni: '1882–1953', temi: 'tanka · morte · amore filiale',                   foto: '' },
  'Mimei Ogawa':           { kanji: '小川未明',     anni: '1882–1961', temi: 'fiabe · malinconia infantile · mare',              foto: '' },
  'Kajii Motojirou':       { kanji: '梶井基次郎',   anni: '1901–1932', temi: 'malattia · luce · frammento lirico',               foto: '' },
  'Fumiko Enchi':          { kanji: '円地文子',     anni: '1905–1986', temi: 'femminile · vendetta · eros represso',             foto: '' },
  'Aya Koda':              { kanji: '幸田文',       anni: '1904–1990', temi: 'natura · famiglia · raffinatezza',                 foto: '' },
};

const CAT_TEMI: Record<string, string> = {
  'Folklore e Fantasmi':   'folklore · spiriti · meraviglia oscura',
  "Romanzo dell'Io":       'confessione · abisso interiore · malinconia',
  'Modernismo':            'città · deriva · identità in frantumi',
  'Naturalismo':           'fame · terra arida · silenzi pesanti',
  'Ero-Guro e Giallo':     'ossessione · ombra · desiderio estremo',
  'Satira e Critica Sociale': 'ironia feroce · potere ridicolo · riso amaro',
};

// ─── AGGREGAZIONE AUTORI ──────────────────────────────────────────────────
interface AutoreEntry {
  nome: string;
  slug: string;
  numRacconti: number;
  categoriaPrevalente: string;
  kanji: string;
  anni: string;
  temi: string;
  foto: string;
}

const autoreMap = new Map<string, { racconti: typeof tuttiRacconti; cats: Record<string, number> }>();

// Prima aggiungi tutti gli autori dai racconti
for (const r of tuttiRacconti) {
  const nome = r.data.author?.trim();
  if (!nome) continue;
  if (!autoreMap.has(nome)) autoreMap.set(nome, { racconti: [], cats: {} });
  const entry = autoreMap.get(nome)!;
  entry.racconti.push(r);
  const cat = r.data.category || '';
  entry.cats[cat] = (entry.cats[cat] || 0) + 1;
}

// FIX #5 — poi aggiungi autori dalla collection che non hanno ancora racconti
for (const a of autoriCollection) {
  const nome = a.data.name?.trim();
  if (!nome || autoreMap.has(nome)) continue;
  autoreMap.set(nome, { racconti: [], cats: {} });
}

const autori: AutoreEntry[] = [...autoreMap.entries()]
  .map(([nome, data]) => {
    const catPrev = Object.entries(data.cats).sort((a, b) => b[1] - a[1])[0]?.[0] ?? '';

    // Priorità: dati dalla collection autori, poi AUTHOR_META statico
    const collEntry = autoriCollection.find(a => a.data.name === nome);
    const meta = AUTHOR_META[nome];

    return {
      nome,
      slug: slugify(nome),
      numRacconti: data.racconti.length,
      categoriaPrevalente: catPrev,
      kanji: collEntry?.data.kanji ?? meta?.kanji ?? nome.slice(0, 2).toUpperCase(),
      anni:  collEntry?.data.anni  ?? meta?.anni  ?? '—',
      temi:  collEntry?.data.temi  ?? meta?.temi  ?? CAT_TEMI[catPrev] ?? 'letteratura · narrazione · memoria',
      foto:  collEntry?.data.foto  ?? meta?.foto  ?? '',
    };
  })
  .sort((a, b) => a.nome.localeCompare(b.nome, 'it'));

// Raggruppa per prima lettera
const perLettera = new Map<string, AutoreEntry[]>();
for (const a of autori) {
  const l = a.nome[0].toUpperCase();
  if (!perLettera.has(l)) perLettera.set(l, []);
  perLettera.get(l)!.push(a);
}
const letterePresenti = new Set([...perLettera.keys()]);
const lettereOrdinate = [...perLettera.keys()].sort();
const alfabeto = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
