<!-- ══════════════════════════════════════════════════
     NUOVE SEZIONI HOMEPAGE
     ── Ultimi Racconti ──
══════════════════════════════════════════════════ -->
<section id="ultimi-racconti">
  <div class="ur-header ur-visible" id="ur-header">
    <span class="ur-eyebrow">Le ultime traduzioni</span>
    <h2 class="ur-title">Ultimi racconti<br>inseriti</h2>
  </div>

  <div class="ur-masonry" id="ur-masonry">
    {ultimiRacconti.map((racconto, index) => {
      let artType = 'moon';
      const cat = racconto.data.category;
      if (cat === "Folklore e Fantasmi") artType = 'moon';
      else if (cat === "Romanzo dell'Io") artType = 'rain';
      else if (cat === "Modernismo") artType = 'city';
      else if (cat === "Naturalismo") artType = 'branch';
      else if (cat === "Ero-Guro e Giallo") artType = 'lantern';
      else {
        const types = ['moon', 'rain', 'branch', 'lantern', 'city'];
        artType = types[index % types.length];
      }

      const heights = ['160px', '220px', '140px', '190px', '160px', '200px'];
      const cardHeight = heights[index % heights.length];
      const delay = (0.05 + index * 0.07).toFixed(2) + 's';

      return (
        <a class="ur-card ur-visible" href={`${import.meta.env.BASE_URL}racconti/${racconto.id}`} style={`transition-delay:${delay}`} key={racconto.id}>
          <div class="ur-card-art" style={`height:${cardHeight}`}>
            {racconto.data.heroImage ? (
              <img 
                class="ur-card-img" 
                src={`${import.meta.env.BASE_URL}${racconto.data.heroImage.replace(/^\//, '')}`} 
                alt={racconto.data.title}
                loading="lazy"
              />
            ) : (
              <canvas class="ur-art-canvas" data-art={artType} style={`height:${cardHeight}`}></canvas>
            )}
          </div>
          <div class="ur-card-body">
            <div class="ur-card-meta">
              <span class="ur-cat">{racconto.data.category}</span>
              <span class="ur-time">{racconto.data.readTime ? `${racconto.data.readTime} min` : '6 min'}</span>
            </div>
            <div class="ur-card-title">{racconto.data.title}</div>
            <p class="ur-card-teaser">{racconto.data.excerpt || racconto.data.description}</p>
          </div>
        </a>
      );
    })}
  </div>
</section>

