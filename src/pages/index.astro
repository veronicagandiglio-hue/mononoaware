<!-- ══════════════════════════════════════════════════
     SCRIPT ① — HERO (invariato)
══════════════════════════════════════════════════ -->
<script is:inline>
// ─────────────────────────────────────────────
//  CONFIG
// ─────────────────────────────────────────────
const IMAGES = [
  'cina.png', 'kimono.png', 'tigre.png', 'corea.png', 'samurai.png', 'demone.png'
];

const PHASE = {
  IDLE:    0,
  REVEAL:  1,
  HOLD:    2,
  FADE:    3,
  PAUSE:   4
};

// ─────────────────────────────────────────────
//  CANVAS SETUP
// ─────────────────────────────────────────────
const canvas  = document.getElementById('c-brush');
const ctx     = canvas.getContext('2d');

function resize() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', () => { resize(); });

// ─────────────────────────────────────────────
//  IMAGE LOADER
// ─────────────────────────────────────────────
const loadedImages = [];

function loadImages(filenames) {
  return Promise.all(filenames.map(name => new Promise(resolve => {
    const img = new Image();
    img.src = `/mnt/user-data/uploads/${name}`;
    img.onload  = () => resolve(img);
    img.onerror = () => {
      const img2 = new Image();
      img2.src = name;
      img2.onload  = () => resolve(img2);
      img2.onerror = () => resolve(null);
    };
  })));
}

// ─────────────────────────────────────────────
//  BRUSH STROKE SIMULATION
// ─────────────────────────────────────────────
const maskCanvas = document.createElement('canvas');
const maskCtx    = maskCanvas.getContext('2d');

function resizeMask() {
  maskCanvas.width  = canvas.width;
  maskCanvas.height = canvas.height;
}
resizeMask();
window.addEventListener('resize', resizeMask);

function buildStroke(w, h) {
  const cx = w * 0.5, cy = h * 0.5;
  const pts = [];
  const count = 18;
  for (let i = 0; i < count; i++) {
    const t = i / (count - 1);
    const x = w * 0.12 + t * w * 0.76 + (Math.random() - 0.5) * w * 0.08;
    const y = cy + Math.sin(t * Math.PI * 1.8) * h * 0.18 + (Math.random() - 0.5) * h * 0.10;
    const r = (h * 0.32) * Math.sin(t * Math.PI) * (0.6 + Math.random() * 0.5);
    pts.push({ x, y, r });
  }
  return pts;
}

// ─────────────────────────────────────────────
//  MAIN ANIMATION STATE
// ─────────────────────────────────────────────
let state       = PHASE.PAUSE;
let imgIndex    = 0;
let progress    = 0;
let phaseTimer  = 0;
let strokePts   = [];

const DURATIONS = {
  [PHASE.REVEAL]: 2200,
  [PHASE.HOLD]:   2500,
  [PHASE.FADE]:   1800,
  [PHASE.PAUSE]:  500
};

let lastTs = null;

function nextImage() {
  imgIndex = (imgIndex + 1) % loadedImages.length;
}

function startReveal() {
  strokePts = buildStroke(canvas.width, canvas.height);
  state      = PHASE.REVEAL;
  progress   = 0;
  phaseTimer = 0;
}

// ─────────────────────────────────────────────
//  DRAW MASK
// ─────────────────────────────────────────────
function drawMask(prog) {
  maskCtx.clearRect(0, 0, maskCanvas.width, maskCanvas.height);
  maskCtx.globalAlpha = 1;

  const visible = Math.ceil(prog * strokePts.length);

  for (let i = 0; i < visible; i++) {
    const p    = strokePts[i];
    const frac = (i === visible - 1) ? (prog * strokePts.length - i) : 1;
    const r    = p.r * frac;
    if (r <= 0) continue;

    const grd = maskCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, r);
    grd.addColorStop(0,   'rgba(0,0,0,1)');
    grd.addColorStop(0.55,'rgba(0,0,0,0.92)');
    grd.addColorStop(0.82,'rgba(0,0,0,0.5)');
    grd.addColorStop(1,   'rgba(0,0,0,0)');

    maskCtx.globalCompositeOperation = 'source-over';
    maskCtx.fillStyle = grd;
    maskCtx.beginPath();
    maskCtx.arc(p.x, p.y, r, 0, Math.PI * 2);
    maskCtx.fill();
  }
}

// ─────────────────────────────────────────────
//  DRAW FRAME
// ─────────────────────────────────────────────
function drawFrame(imageAlpha, maskProg) {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const img = loadedImages[imgIndex];
  if (!img) return;

  drawMask(maskProg);

  const iw = img.naturalWidth  || img.width;
  const ih = img.naturalHeight || img.height;
  const scale = Math.max(canvas.width / iw, canvas.height / ih) * 0.85;
  const dw = iw * scale;
  const dh = ih * scale;
  const dx = (canvas.width  - dw) / 2;
  const dy = (canvas.height - dh) / 2;

  const imgOff = document.createElement('canvas');
  imgOff.width  = canvas.width;
  imgOff.height = canvas.height;
  const iCtx = imgOff.getContext('2d');

  iCtx.globalAlpha = 1;
  iCtx.drawImage(img, dx, dy, dw, dh);
  iCtx.globalCompositeOperation = 'destination-in';
  iCtx.drawImage(maskCanvas, 0, 0);

  ctx.globalAlpha = imageAlpha;
  ctx.drawImage(imgOff, 0, 0);
  ctx.globalAlpha = 1;
}

// ─────────────────────────────────────────────
//  EASING
// ─────────────────────────────────────────────
function easeInOutHero(t) {
  return t < 0.5 ? 2*t*t : -1 + (4-2*t)*t;
}
function easeOutHero(t) {
  return 1 - Math.pow(1 - t, 3);
}

// ─────────────────────────────────────────────
//  TICK
// ─────────────────────────────────────────────
function tick(ts) {
  requestAnimationFrame(tick);

  if (!lastTs) { lastTs = ts; return; }
  const dt = Math.min(ts - lastTs, 60);
  lastTs = ts;

  phaseTimer += dt;

  const dur  = DURATIONS[state];
  const prog = Math.min(phaseTimer / dur, 1);

  switch (state) {

    case PHASE.PAUSE:
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      if (prog >= 1) { startReveal(); }
      break;

    case PHASE.REVEAL: {
      const maskProg = easeOutHero(prog);
      const imgAlpha = easeOutHero(Math.min(prog * 1.4, 1));
      drawFrame(imgAlpha, maskProg);
      if (prog >= 1) { state = PHASE.HOLD; phaseTimer = 0; }
      break;
    }

    case PHASE.HOLD: {
      const breath = 0.88 + 0.12 * Math.sin(phaseTimer * 0.0012 * Math.PI * 2);
      drawFrame(breath, 1);
      if (prog >= 1) { state = PHASE.FADE; phaseTimer = 0; }
      break;
    }

    case PHASE.FADE: {
      const imgAlpha = 1 - easeInOutHero(prog);
      const maskProg = 1 - easeInOutHero(prog * 0.9);
      drawFrame(imgAlpha, maskProg);
      if (prog >= 1) {
        nextImage();
        state = PHASE.PAUSE;
        phaseTimer = 0;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
      break;
    }
  }
}

// ─────────────────────────────────────────────
//  UI REVEAL
// ─────────────────────────────────────────────
function revealUI() {
  const corners = document.querySelectorAll('.corner');
  corners.forEach((c, i) => {
    setTimeout(() => c.classList.add('show'), 400 + i * 120);
  });

  setTimeout(() => {
    const kanjiEl = document.querySelector('.kanji');
    if (kanjiEl) kanjiEl.classList.add('show');
    const kanjiSubEl = document.querySelector('.kanji-sub');
    if (kanjiSubEl) kanjiSubEl.classList.add('show');
  }, 600);

  setTimeout(() => {
    const el = document.querySelector('.eyebrow');
    if (el) el.classList.add('show');
  }, 800);

  const words = document.querySelectorAll('h1 .word span');
  words.forEach((w, i) => {
    setTimeout(() => {
      w.style.transform = 'translateY(0)';
      w.style.opacity   = '1';
    }, 1100 + i * 220);
  });

  setTimeout(() => {
    const el = document.querySelector('.sub-line');
    if (el) el.classList.add('show');
  }, 1900);
  setTimeout(() => {
    const el = document.querySelector('.cta');
    if (el) el.classList.add('show');
  }, 2200);
  setTimeout(() => {
    const el = document.querySelector('.scroll-hint');
    if (el) el.classList.add('show');
  }, 2800);
}

// ─────────────────────────────────────────────
//  INIT HERO
// ─────────────────────────────────────────────
loadImages(IMAGES).then(imgs => {
  imgs.forEach((img) => {
    if (img) loadedImages.push(img);
    else {
      const ph = document.createElement('canvas');
      ph.width = 100; ph.height = 100;
      const pCtx = ph.getContext('2d');
      const g = pCtx.createRadialGradient(400,350,20,400,350,340);
      g.addColorStop(0, 'rgba(30,20,14,0.9)');
      g.addColorStop(0.6,'rgba(30,20,14,0.5)');
      g.addColorStop(1, 'rgba(30,20,14,0)');
      pCtx.fillStyle = g;
      pCtx.fillRect(0,0,800,800);
      loadedImages.push(ph);
    }
  });

  revealUI();
  requestAnimationFrame(tick);
});
</script>

<!-- ══════════════════════════════════════════════════
     SCRIPT ② — NUOVE SEZIONI
══════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  /* ── MNA Cinematic Reveal ── */
  function observeEl(id, cls, root) {
    const el = document.getElementById(id);
    if (!el) return;
    new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        el.classList.add(cls);
      }
    }, { threshold: root || 0.2 }).observe(el);
  }

  observeEl('mna-p1', 'mna-visible', 0.3);
  observeEl('mna-p2', 'mna-visible', 0.3);
  observeEl('mna-p3', 'mna-visible', 0.25);

  /* ── Ultimi Racconti reveal ── */
  const urHeader = document.getElementById('ur-header');
  if (urHeader) {
    new IntersectionObserver(e => {
      if (e[0].isIntersecting) urHeader.classList.add('ur-visible');
    }, { threshold: 0.2 }).observe(urHeader);
  }
  document.querySelectorAll('.ur-card').forEach(card => {
    new IntersectionObserver(e => {
      if (e[0].isIntersecting) card.classList.add('ur-visible');
    }, { threshold: 0.1 }).observe(card);
  });

  /* ── Mini canvas art per card racconti ── */
  const MINI_SCENES = {
    moon(ctx, w, h) {
      ctx.fillStyle = '#070810'; ctx.fillRect(0,0,w,h);
      const mg = ctx.createRadialGradient(w*.5,h*.3,0,w*.5,h*.3,h*.5);
      mg.addColorStop(0,'rgba(200,215,248,0.55)');
      mg.addColorStop(.5,'rgba(160,180,230,0.12)');
      mg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=mg; ctx.fillRect(0,0,w,h);
      ctx.beginPath(); ctx.arc(w*.5,h*.3,h*.1,0,Math.PI*2);
      ctx.fillStyle='rgba(215,225,252,.7)'; ctx.fill();
    },
    rain(ctx, w, h) {
      ctx.fillStyle='#060c12'; ctx.fillRect(0,0,w,h);
      const wg=ctx.createRadialGradient(w*.5,h*.4,0,w*.5,h*.4,h*.4);
      wg.addColorStop(0,'rgba(200,148,60,.18)');
      wg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=wg; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha=.18;
      for(let i=0;i<8;i++){
        const rx=(i*17)%w, ry=(i*22)%h;
        ctx.strokeStyle='rgba(140,165,200,1)';ctx.lineWidth=.6;
        ctx.beginPath();ctx.moveTo(rx,ry);ctx.lineTo(rx-1.5,ry+9);ctx.stroke();
      }
      ctx.globalAlpha=1;
    },
    branch(ctx, w, h) {
      ctx.fillStyle='#080806'; ctx.fillRect(0,0,w,h);
      ctx.strokeStyle='rgba(200,192,168,.28)'; ctx.lineWidth=1; ctx.lineCap='round';
      ctx.beginPath(); ctx.moveTo(w*.5,h);
      ctx.quadraticCurveTo(w*.5, h*.55, w*.38, h*.2); ctx.stroke();
      ctx.globalAlpha=.18;
      ctx.beginPath(); ctx.moveTo(w*.42,h*.5); ctx.lineTo(w*.7,h*.28); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(w*.42,h*.35); ctx.lineTo(w*.14,h*.14); ctx.stroke();
      ctx.globalAlpha=1;
    },
    lantern(ctx, w, h) {
      ctx.fillStyle='#060305'; ctx.fillRect(0,0,w,h);
      const lg=ctx.createRadialGradient(w*.5,h*.35,0,w*.5,h*.35,h*.4);
      lg.addColorStop(0,'rgba(220,48,28,.35)');
      lg.addColorStop(.5,'rgba(175,28,18,.1)');
      lg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=lg; ctx.fillRect(0,0,w,h);
    },
    city(ctx, w, h) {
      ctx.fillStyle='#050810'; ctx.fillRect(0,0,w,h);
      const ng=ctx.createRadialGradient(w*.3,h*.4,0,w*.3,h*.4,h*.5);
      ng.addColorStop(0,'rgba(60,100,220,.12)');
      ng.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=ng; ctx.fillRect(0,0,w,h);
      const ng2=ctx.createRadialGradient(w*.75,h*.5,0,w*.75,h*.5,h*.4);
      ng2.addColorStop(0,'rgba(220,60,80,.09)');
      ng2.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=ng2; ctx.fillRect(0,0,w,h);
    }
  };

  function renderMiniArt(canvas) {
    const type = canvas.dataset.art;
    const fn = MINI_SCENES[type];
    if (!fn) return;
    const parent = canvas.parentElement;
    canvas.width = parent.offsetWidth || 300;
    canvas.height = parent.offsetHeight || 160;
    fn(canvas.getContext('2d'), canvas.width, canvas.height);
  }

  document.querySelectorAll('.ur-art-canvas').forEach(c => {
    renderMiniArt(c);
  });
  window.addEventListener('resize', () => {
    document.querySelectorAll('.ur-art-canvas').forEach(c => renderMiniArt(c));
  });

  /* ── Frase dal Giappone ── */
  const FRASI = [
    '«Gli uomini soffrono più per ciò che immaginano.»',
    '«La tristezza è bella quando si sa portarla.»',
    '«Il fiore di ciliegio è bello perché cade.»',
    '«Ogni addio contiene già un ritorno impossibile.»',
    '«Il silenzio tra due persone dice più di mille parole.»',
    '«Chi vive troppo in fretta non vede niente.»',
    '«L\'impermanenza non è una perdita: è la forma della bellezza.»'
  ];
  const fgQuote = document.getElementById('fg-quote');
  if (fgQuote) {
    fgQuote.textContent = FRASI[Math.floor(Math.random() * FRASI.length)];
  }
  const fgInner = document.getElementById('fg-inner');
  if (fgInner) {
    new IntersectionObserver(e => {
      if (e[0].isIntersecting) fgInner.classList.add('fg-visible');
    }, { threshold: 0.3 }).observe(fgInner);
  }

  /* ── Autori reveal ── */
  const auHeader = document.getElementById('autori-header');
  if (auHeader) {
    new IntersectionObserver(e => {
      if (e[0].isIntersecting) auHeader.classList.add('au-visible');
    }, { threshold: 0.2 }).observe(auHeader);
  }
  for (let i = 0; i < 5; i++) {
    const el = document.getElementById('au-' + i);
    if (el) {
      new IntersectionObserver(e => {
        if (e[0].isIntersecting) el.classList.add('au-visible');
      }, { threshold: 0.15 }).observe(el);
    }
  }

  /* ── Mini brush portrait per autori ── */
  const AUTHOR_COLORS = {
    akutagawa: ['rgba(80,40,30,.6)', 'rgba(140,60,40,.3)'],
    tanizaki:  ['rgba(40,30,80,.6)', 'rgba(80,60,140,.3)'],
    kawabata:  ['rgba(30,60,80,.6)', 'rgba(60,120,140,.3)'],
    soseki:    ['rgba(40,60,30,.6)', 'rgba(80,120,60,.3)'],
    mishima:   ['rgba(70,20,20,.6)', 'rgba(140,40,30,.3)']
  };

  document.querySelectorAll('[data-autore]').forEach(canvas => {
    const key = canvas.dataset.autore;
    const [c1, c2] = AUTHOR_COLORS[key] || ['rgba(60,40,30,.5)', 'rgba(80,60,40,.3)'];
    const size = canvas.parentElement.offsetWidth || 88;
    canvas.width = size; canvas.height = size;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#0e0c0a'; ctx.fillRect(0,0,size,size);
    const g = ctx.createRadialGradient(size*.5,size*.4,0,size*.5,size*.4,size*.55);
    g.addColorStop(0, c1);
    g.addColorStop(.6, c2);
    g.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = g; ctx.fillRect(0,0,size,size);
    /* piccole pennellate decorative */
    ctx.globalAlpha = 0.12;
    ctx.strokeStyle = 'rgba(240,230,210,1)';
    ctx.lineWidth = size * 0.012;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(size*.3, size*.65); ctx.lineTo(size*.7, size*.35); ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(size*.25, size*.5); ctx.lineTo(size*.55, size*.25); ctx.stroke();
    ctx.globalAlpha = 1;
  });



})();
</script>

<!-- ══════════════════════════════════════════════════
     SCRIPT — MODALE CATEGORIA
══════════════════════════════════════════════════ -->
<script define:vars={{ dynamicCatData }}>
(function () {

/* ── Dati per categoria ── */
const CAT_DATA = dynamicCatData;

/* ── Disegno hero modale ── */
function drawModalHero(canvas, scene) {
  canvas.width  = canvas.offsetWidth  || 680;
  canvas.height = canvas.offsetHeight || 400;
  const ctx = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;

  const scenes = {
    moon() {
      ctx.fillStyle='#060810'; ctx.fillRect(0,0,w,h);
      for (let i=0;i<3;i++){
        const fx=w*(0.2+i*0.28+Math.sin(i)*0.06);
        const g=ctx.createRadialGradient(fx,h*0.6,0,fx,h*0.6,h*0.55);
        g.addColorStop(0,`rgba(100,140,180,${0.06+i*0.02})`);
        g.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=g; ctx.fillRect(0,0,w,h);
      }
      const mg=ctx.createRadialGradient(w*.5,h*.24,0,w*.5,h*.24,h*.26);
      mg.addColorStop(0,'rgba(210,220,248,0.65)');
      mg.addColorStop(.45,'rgba(180,195,235,0.14)');
      mg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=mg; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha=.76;
      ctx.beginPath(); ctx.arc(w*.5,h*.24,h*.088,0,Math.PI*2);
      ctx.fillStyle='rgba(225,232,252,.8)'; ctx.fill();
      ctx.globalAlpha=1;
      ctx.fillStyle='rgba(240,235,255,0.5)';
      [[.14,.1],[.72,.07],[.88,.2],[.3,.14],[.6,.04],[.82,.33]].forEach(([sx,sy])=>{
        ctx.beginPath(); ctx.arc(w*sx,h*sy,0.9,0,Math.PI*2); ctx.fill();
      });
    },
    rain() {
      ctx.fillStyle='#080c12'; ctx.fillRect(0,0,w,h);
      const wg=ctx.createRadialGradient(w*.45,h*.4,0,w*.45,h*.4,h*.55);
      wg.addColorStop(0,'rgba(200,148,60,.22)');
      wg.addColorStop(.6,'rgba(150,100,40,.07)');
      wg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=wg; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha=.25;
      for(let i=0;i<28;i++){
        const rx=(i*37+13)%w, ry=(i*29+7)%h;
        ctx.strokeStyle='rgba(140,165,200,1)'; ctx.lineWidth=.65;
        ctx.beginPath(); ctx.moveTo(rx,ry); ctx.lineTo(rx-2,ry+14); ctx.stroke();
      }
      ctx.globalAlpha=1;
    },
    city() {
      ctx.fillStyle='#050810'; ctx.fillRect(0,0,w,h);
      [[w*.25,h*.45,60,120,220],[w*.7,h*.3,220,60,80],[w*.85,h*.6,60,200,180]].forEach(([cx,cy,r,g,b])=>{
        const ng=ctx.createRadialGradient(cx,cy,0,cx,cy,h*.6);
        ng.addColorStop(0,`rgba(${r},${g},${b},0.1)`);
        ng.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=ng; ctx.fillRect(0,0,w,h);
      });
    },
    branch() {
      ctx.fillStyle='#080806'; ctx.fillRect(0,0,w,h);
      const fog=ctx.createLinearGradient(0,h*.4,0,h);
      fog.addColorStop(0,'rgba(90,85,68,0)');
      fog.addColorStop(1,'rgba(70,65,50,.09)');
      ctx.fillStyle=fog; ctx.fillRect(0,0,w,h);
      ctx.strokeStyle='rgba(200,192,168,.28)'; ctx.lineWidth=1.2; ctx.lineCap='round';
      ctx.beginPath(); ctx.moveTo(w*.5,h);
      ctx.quadraticCurveTo(w*.48,h*.55,w*.38,h*.2); ctx.stroke();
      ctx.globalAlpha=.2;
      [[.42,.5,.16,.35],[.44,.38,.74,.24],[.4,.28,.12,.11]].forEach(([x1,y1,x2,y2])=>{
        ctx.beginPath(); ctx.moveTo(w*x1,h*y1); ctx.lineTo(w*x2,h*y2); ctx.stroke();
      });
      ctx.globalAlpha=1;
    },
    lantern() {
      ctx.fillStyle='#060305'; ctx.fillRect(0,0,w,h);
      const lg=ctx.createRadialGradient(w*.5,h*.38,0,w*.5,h*.38,h*.44);
      lg.addColorStop(0,'rgba(220,48,28,.44)');
      lg.addColorStop(.5,'rgba(175,28,18,.15)');
      lg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=lg; ctx.fillRect(0,0,w,h);
      const ag=ctx.createRadialGradient(w*.5,h*.38,0,w*.5,h*.38,h*.7);
      ag.addColorStop(0,'rgba(160,24,14,.07)');
      ag.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=ag; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha=.55;
      ctx.strokeStyle='rgba(220,75,38,.6)'; ctx.lineWidth=1;
      ctx.strokeRect(w*.4,h*.22,w*.2,h*.28);
      ctx.beginPath(); ctx.moveTo(w*.5,h*.14); ctx.lineTo(w*.5,h*.22); ctx.stroke();
      ctx.globalAlpha=1;
    }
  };
  (scenes[scene] || scenes.moon)();
}

/* ── Mini art storie nel modale ── */
function drawStoryArt(canvas, scene) {
  canvas.width = 56; canvas.height = 72;
  const ctx = canvas.getContext('2d');
  const w = 56, h = 72;
  const mini = {
    moon()   { ctx.fillStyle='#070810'; ctx.fillRect(0,0,w,h); const g=ctx.createRadialGradient(w*.5,h*.3,0,w*.5,h*.3,h*.4); g.addColorStop(0,'rgba(200,215,248,.45)'); g.addColorStop(1,'rgba(0,0,0,0)'); ctx.fillStyle=g; ctx.fillRect(0,0,w,h); ctx.beginPath(); ctx.arc(w*.5,h*.28,h*.09,0,Math.PI*2); ctx.fillStyle='rgba(220,228,252,.6)'; ctx.fill(); },
    rain()   { ctx.fillStyle='#06080f'; ctx.fillRect(0,0,w,h); const g=ctx.createRadialGradient(w*.5,h*.4,0,w*.5,h*.4,h*.38); g.addColorStop(0,'rgba(185,135,48,.18)'); g.addColorStop(1,'rgba(0,0,0,0)'); ctx.fillStyle=g; ctx.fillRect(0,0,w,h); },
    city()   { ctx.fillStyle='#050810'; ctx.fillRect(0,0,w,h); const g=ctx.createRadialGradient(w*.3,h*.4,0,w*.3,h*.4,h*.44); g.addColorStop(0,'rgba(60,100,200,.13)'); g.addColorStop(1,'rgba(0,0,0,0)'); ctx.fillStyle=g; ctx.fillRect(0,0,w,h); },
    branch() { ctx.fillStyle='#080806'; ctx.fillRect(0,0,w,h); ctx.strokeStyle='rgba(190,180,155,.2)'; ctx.lineWidth=.8; ctx.lineCap='round'; ctx.beginPath(); ctx.moveTo(w*.5,h); ctx.quadraticCurveTo(w*.5,h*.5,w*.35,h*.15); ctx.stroke(); },
    lantern(){ ctx.fillStyle='#060305'; ctx.fillRect(0,0,w,h); const g=ctx.createRadialGradient(w*.5,h*.35,0,w*.5,h*.35,h*.38); g.addColorStop(0,'rgba(210,44,24,.38)'); g.addColorStop(1,'rgba(0,0,0,0)'); ctx.fillStyle=g; ctx.fillRect(0,0,w,h); }
  };
  (mini[scene] || mini.moon)();
}

/* ── Popola il modale con i dati della categoria ── */
function populateModal(catKey) {
  const d = CAT_DATA[catKey];
  if (!d) return;

  document.getElementById('cm-eyebrow').textContent = d.eyebrow;
  document.getElementById('cm-title').textContent   = d.title;
  document.getElementById('cm-evocativa').textContent = d.evocativa;

  const heroCanvas = document.getElementById('cm-hero-canvas');
  drawModalHero(heroCanvas, d.scene);

  const storiesEl = document.getElementById('cm-stories');
  storiesEl.innerHTML = '';
  d.storie.forEach(s => {
    const a = document.createElement('a');
    a.className = 'cm-story';
    a.href = s.slug;
    const artDiv = document.createElement('div');
    artDiv.className = 'cm-story-art';
    const c = document.createElement('canvas');
    artDiv.appendChild(c);
    const infoDiv = document.createElement('div');
    infoDiv.className = 'cm-story-info';
    const metaDiv = document.createElement('div');
    metaDiv.className = 'cm-story-meta';
    const catSpan = document.createElement('span');
    catSpan.className = 'cm-story-cat';
    catSpan.textContent = d.eyebrow;
    const timeSpan = document.createElement('span');
    timeSpan.className = 'cm-story-time';
    timeSpan.textContent = s.minuti + ' min';
    metaDiv.appendChild(catSpan);
    metaDiv.appendChild(timeSpan);
    const titleDiv = document.createElement('div');
    titleDiv.className = 'cm-story-title';
    titleDiv.textContent = s.titolo;
    const teaserDiv = document.createElement('div');
    teaserDiv.className = 'cm-story-teaser';
    teaserDiv.textContent = s.teaser;
    infoDiv.appendChild(metaDiv);
    infoDiv.appendChild(titleDiv);
    infoDiv.appendChild(teaserDiv);
    a.appendChild(artDiv);
    a.appendChild(infoDiv);
    storiesEl.appendChild(a);
    drawStoryArt(c, d.scene);
  });

  const ctaEl = document.getElementById('cm-cta');
  document.getElementById('cm-cta-text').textContent = d.cta;
  ctaEl.href = d.href;
}

/* ── Apri / chiudi ── */
const modal    = document.getElementById('cat-modal');
const backdrop = document.getElementById('cm-backdrop');
const closeBtn = document.getElementById('cm-close');
let lastFocus  = null;

function openModal(catKey) {
  populateModal(catKey);
  modal.hidden = false;
  document.body.style.overflow = 'hidden';
  requestAnimationFrame(() => {
    requestAnimationFrame(() => { modal.classList.add('cm-open'); });
  });
  lastFocus = document.activeElement;
  setTimeout(() => closeBtn && closeBtn.focus(), 400);
}

function closeModal() {
  modal.classList.remove('cm-open');
  document.body.style.overflow = '';
  setTimeout(() => {
    modal.hidden = true;
    if (lastFocus) lastFocus.focus();
  }, 660);
}

document.querySelectorAll('.atm-card[data-cat]').forEach(btn => {
  btn.addEventListener('click', () => openModal(btn.dataset.cat));
});

backdrop.addEventListener('click', closeModal);
closeBtn.addEventListener('click', closeModal);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && !modal.hidden) closeModal();
});

modal.addEventListener('keydown', e => {
  if (e.key !== 'Tab') return;
  const focusable = Array.from(modal.querySelectorAll('button, a[href]'));
  const first = focusable[0], last = focusable[focusable.length - 1];
  if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
  else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
});

})();
</script>


<!-- ══════════════════════════════════════════════════
     SCRIPT ③ — IL RACCONTO DEL GIORNO
══════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  const weatherCanvas = document.getElementById('weather-canvas');
  if (!weatherCanvas) return;

  const wCtx = weatherCanvas.getContext('2d');
  let wAnimId  = null;
  let isVisible = false;

  // Expanding central blot properties
  let centerBlotProgress = 0;
  let centerBlotActive = false;

  function resizeWeather() {
    const sec = weatherCanvas.parentElement;
    weatherCanvas.width  = sec.offsetWidth;
    weatherCanvas.height = sec.offsetHeight;
  }
  resizeWeather();
  window.addEventListener('resize', resizeWeather);

  /* Flow Field & Fraying Particles */
  const inkBlots = [];
  const frayedParticles = [];

  function initParticles() {
    const w = weatherCanvas.width, h = weatherCanvas.height;
    inkBlots.length = 0;
    frayedParticles.length = 0;

    // Create 16-24 main organic ink blots
    const count = Math.max(16, Math.round((w * h) / 75000));
    for (let i = 0; i < count; i++) {
      const size = 60 + Math.random() * 160;
      // Start them distributed across and off-screen to the right
      inkBlots.push({
        x: Math.random() * (w * 1.5),
        y: Math.random() * h,
        size,
        baseVx: -(0.8 + Math.random() * 1.4), // base speed to the left
        baseVy: (Math.random() - 0.5) * 0.3,
        alpha: 0.12 + Math.random() * 0.14,
        phase: Math.random() * Math.PI * 2,
        seed: Math.random() * 100
      });
    }
  }
  initParticles();
  window.addEventListener('resize', () => { resizeWeather(); initParticles(); });

  function getFlowVector(x, y, time) {
    // Wind is primarily leftwards
    // Flow Field creates a wave-like up/down vector
    const freqX = 0.0022;
    const freqY = 0.0018;
    const speed = 0.0007;
    const forceY = Math.sin(x * freqX + time * speed) * Math.cos(y * freqY - time * speed * 0.8) * 1.8;
    return { x: -1.6, y: forceY };
  }

  // Draw irregular Sumi-e style organic spot — wind-stretched ellipse, not a circle
  const INK = '148, 136, 120';
  function drawSumiSpot(ctx, cx, cy, radius, alpha) {
    ctx.save();
    ctx.translate(cx, cy);
    // Rotate slightly in wind direction (mostly horizontal)
    ctx.rotate(-0.15 + (Math.sin(cx * 0.003) * 0.12));
    
    // Stretched horizontally like ink blown by wind
    const rx = radius * (1.6 + Math.sin(cx * 0.007) * 0.3); // wide
    const ry = radius * (0.55 + Math.cos(cy * 0.009) * 0.1);  // flat
    
    const coreGrad = ctx.createRadialGradient(0, 0, 0, 0, 0, rx);
    coreGrad.addColorStop(0, `rgba(${INK}, ${alpha * 0.78})`);
    coreGrad.addColorStop(0.4, `rgba(${INK}, ${alpha * 0.32})`);
    coreGrad.addColorStop(0.8, `rgba(${INK}, ${alpha * 0.07})`);
    coreGrad.addColorStop(1, `rgba(${INK}, 0)`);
    
    ctx.fillStyle = coreGrad;
    ctx.beginPath();
    ctx.ellipse(0, 0, rx, ry, 0, 0, Math.PI * 2);
    ctx.fill();
    
    ctx.restore();
  }

  let lastTime = 0;
  function drawWeather(t) {
    if (!isVisible) return;
    wAnimId = requestAnimationFrame(drawWeather);
    const now = t || performance.now();
    const dt = Math.min(40, now - (lastTime || now)) / 1000; // seconds, capped
    lastTime = now;

    const w = weatherCanvas.width, h = weatherCanvas.height;
    wCtx.clearRect(0, 0, w, h);

    // Draw central emerging ink blot
    if (centerBlotActive) {
      centerBlotProgress += dt * 0.45; // takes ~2.2 seconds to expand
      if (centerBlotProgress > 1) centerBlotProgress = 1;
      
      const cx = w * 0.28; // position behind the title
      const cy = h * 0.46;
      const maxRadius = Math.min(w, h) * 0.42;
      
      // Cubic ease-out
      const easeVal = 1 - Math.pow(1 - centerBlotProgress, 3);
      const currentRadius = maxRadius * easeVal;
      const currentAlpha = 0.58 * easeVal;
      
      const g = wCtx.createRadialGradient(cx, cy, 0, cx, cy, currentRadius * 1.3);
      g.addColorStop(0, `rgba(${INK}, ${currentAlpha * 0.28})`);
      g.addColorStop(0.45, `rgba(${INK}, ${currentAlpha * 0.1})`);
      g.addColorStop(1, `rgba(${INK}, 0)`);
      
      wCtx.save();
      wCtx.translate(cx, cy);
      wCtx.scale(1.4, 0.75); // slightly elliptical, not a perfect circle
      wCtx.fillStyle = g;
      wCtx.beginPath();
      wCtx.arc(0, 0, currentRadius, 0, Math.PI * 2);
      wCtx.fill();
      wCtx.restore();
    }

    // Update and draw parent ink blots
    inkBlots.forEach(b => {
      const flow = getFlowVector(b.x, b.y, now);
      
      b.x += (b.baseVx + flow.x * 0.4) * (dt * 60);
      b.y += (b.baseVy + flow.y * 0.8) * (dt * 60);

      const visFactor = Math.max(0, Math.min(1, (b.x + b.size * 0.5) / (w * 1.1)));
      const drawAlpha = b.alpha * visFactor;

      drawSumiSpot(wCtx, b.x, b.y, b.size * 0.5, drawAlpha);

      // Shedding - Fraying into smaller particles (Sfilacciamento)
      if (isVisible && Math.random() < 0.22 && drawAlpha > 0.02) {
        frayedParticles.push({
          x: b.x + (Math.random() - 0.5) * (b.size * 0.2),
          y: b.y + (Math.random() - 0.5) * (b.size * 0.2),
          size: b.size * (0.08 + Math.random() * 0.14),
          vx: b.baseVx * (1.1 + Math.random() * 0.4), // fly faster to the left
          vy: b.baseVy + (Math.random() - 0.5) * 1.5,
          alpha: drawAlpha * (0.65 + Math.random() * 0.25),
          life: 1.0,
          decay: 0.8 + Math.random() * 0.9 // die off in 0.6 - 1.2s
        });
      }

      if (b.x + b.size < -50) {
        b.x = w + 50 + Math.random() * (w * 0.5);
        b.y = Math.random() * h;
        b.baseVx = -(0.8 + Math.random() * 1.4);
      }
    });

    // Update and draw frayed particles (Disgregazione e sfilacciamento nel vento)
    for (let i = frayedParticles.length - 1; i >= 0; i--) {
      const p = frayedParticles[i];
      const flow = getFlowVector(p.x, p.y, now);

      p.x += (p.vx + flow.x * 0.8) * (dt * 60);
      p.y += (p.vy + flow.y * 1.4) * (dt * 60);
      p.life -= dt * p.decay;

      if (p.life <= 0 || p.x < -10) {
        frayedParticles.splice(i, 1);
        continue;
      }

      const drawAlpha = p.alpha * p.life;
      const drawW = p.size * (0.3 + p.life * 0.7) * 1.8; // elongated horizontally
      const drawH = p.size * (0.3 + p.life * 0.7) * 0.5;

      const g = wCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, drawW);
      g.addColorStop(0, `rgba(${INK}, ${drawAlpha * 0.7})`);
      g.addColorStop(0.6, `rgba(${INK}, ${drawAlpha * 0.2})`);
      g.addColorStop(1, `rgba(${INK}, 0)`);
      
      wCtx.save();
      wCtx.fillStyle = g;
      wCtx.beginPath();
      wCtx.ellipse(p.x, p.y, drawW, drawH, -0.1, 0, Math.PI * 2);
      wCtx.fill();
      wCtx.restore();
    }
  }

  const rgSection = document.getElementById('racconto-giorno');
  const rgContent = document.getElementById('rg-content');

  const rgObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      isVisible = e.isIntersecting;
      if (isVisible) {
        rgContent && rgContent.classList.add('visible');
        centerBlotProgress = 0;
        centerBlotActive = true;
        lastTime = performance.now();
        drawWeather();
      } else {
        wAnimId && cancelAnimationFrame(wAnimId);
      }
    });
  }, { threshold: 0.15 });

  if (rgSection) rgObs.observe(rgSection);
})();
</script>

<!-- ══════════════════════════════════════════════════
     SCRIPT ④ — LA MAPPA DELLE STORIE
══════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  const DATI = {
    japan: {
      name:   'Osaka',
      kanji:  '大阪',
      phrase: 'Dove il mondo visibile confina con l\'invisibile tra le luci del porto.',
      themes: ['Istinto', 'Passione', 'Mistero', 'Umanità']
    },
    china: {
      name:   'Tokyo',
      kanji:  '東京',
      phrase: 'Dove l\'asfalto incontra la solitudine, e la modernità divora il tempo.',
      themes: ['Metropoli', 'Alienazione', 'Caos', 'Oscurità']
    },
    korea: {
      name:   'Kyoto',
      kanji:  '京都市',
      phrase: 'Il riflesso di un\'ombra antica che danza tra i templi e il silenzio.',
      themes: ['Estetica', 'Memoria', 'Silenzio', 'Impermanenza', 'Sogno']
    },
    india: {
      name:   'Kamakura',
      kanji:  '鎌倉',
      phrase: 'Un rifugio tra l\'azzurro del mare e il verde dei boschi sacri.',
      themes: ['Ritiro', 'Orizzonte', 'Solitudine', 'Melanconia']
    }
  };

  const panel     = document.getElementById('map-panel');
  const elKanji   = document.getElementById('panel-kanji');
  const elName    = document.getElementById('panel-country-name');
  const elPhrase  = document.getElementById('panel-phrase');
  const elThemes  = document.getElementById('panel-themes');
  const btnClose  = document.getElementById('panel-close');

  let active = null;

  function openPanel(country) {
    const d = DATI[country];
    if (!d || !panel) return;
    active = country;

    elKanji.textContent  = d.kanji;
    elName.textContent   = d.name;
    elPhrase.textContent = d.phrase;
    elThemes.innerHTML   = d.themes.map(t => `<li>${t}</li>`).join('');
    panel.classList.add('open');

    /* Evidenzia forma paese */
    document.querySelectorAll('.country-shape, .cgroup').forEach(el => {
      el.classList.toggle('sel', el.dataset.country === country);
    });
    document.querySelectorAll('.hs').forEach(el => {
      el.classList.toggle('active', el.dataset.country === country);
    });
  }

  function closePanel() {
    active = null;
    panel && panel.classList.remove('open');
    document.querySelectorAll('.country-shape, .cgroup, .hs').forEach(el => {
      el.classList.remove('sel', 'active');
    });
  }

  /* Click su hotspot e forme */
  document.querySelectorAll('.hs, .country-shape, .cgroup').forEach(el => {
    el.addEventListener('click', () => {
      const c = el.dataset.country;
      if (!c) return;
      active === c ? closePanel() : openPanel(c);
    });
    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const c = el.dataset.country;
        if (c) active === c ? closePanel() : openPanel(c);
      }
    });
  });

  btnClose && btnClose.addEventListener('click', closePanel);

  /* Chiudi pannello quando la sezione esce dal viewport */
  const mapSection = document.getElementById('mappa-storie');
  if (mapSection) {
    new IntersectionObserver(entries => {
      entries.forEach(e => { if (!e.isIntersecting) closePanel(); });
    }, { threshold: 0 }).observe(mapSection);
  }

  /* Anima header al primo scroll */
  const mapHeader = document.getElementById('map-header');
  if (mapHeader) {
    new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          mapHeader.classList.add('visible');
        }
      });
    }, { threshold: 0.35 }).observe(mapHeader);
  }
})();
</script>

<script is:inline>
(function () {
  const SCENES = {
    moon(ctx, w, h, t) {
      ctx.fillStyle = '#060810'; ctx.fillRect(0, 0, w, h);
      for (let i = 0; i < 3; i++) {
        const fx = w * (0.25 + i*0.22 + Math.sin(t*0.0008 + i)*0.08);
        const g = ctx.createRadialGradient(fx, h*0.65, 0, fx, h*0.65, h*0.5);
        g.addColorStop(0, `rgba(130,148,185,${0.07+i*0.02})`);
        g.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = g; ctx.fillRect(0,0,w,h);
      }
      const mg = ctx.createRadialGradient(w*.5, h*.27, 0, w*.5, h*.27, h*.22);
      mg.addColorStop(0,'rgba(210,220,248,0.7)');
      mg.addColorStop(.4,'rgba(180,195,235,0.18)');
      mg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = mg; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha = .78;
      ctx.beginPath(); ctx.arc(w*.5, h*.27, h*.085, 0, Math.PI*2);
      ctx.fillStyle='rgba(225,232,252,.82)'; ctx.fill();
      ctx.globalAlpha = 1;
    },
    rain(ctx, w, h, t) {
      ctx.fillStyle = '#080c10'; ctx.fillRect(0, 0, w, h);
      const wg = ctx.createRadialGradient(w*.5,h*.44,0, w*.5,h*.44,h*.42);
      wg.addColorStop(0,'rgba(210,158,68,.2)');
      wg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = wg; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha = .22;
      for (let i = 0; i < 14; i++) {
        const rx = (i*13 + Math.sin(t*.001+i)*4 + w) % w;
        const ry = ((t*.045 + i*22) % (h+10)) - 5;
        ctx.strokeStyle='rgba(140,165,200,1)';
        ctx.lineWidth=.6;
        ctx.beginPath(); ctx.moveTo(rx,ry); ctx.lineTo(rx-1.5, ry+9); ctx.stroke();
      }
      ctx.globalAlpha = 1;
    },
    city(ctx, w, h, t) {
      ctx.fillStyle = '#050810'; ctx.fillRect(0,0,w,h);
      const neons = [
        [w*.2, h*.4, 60,120,220, t*.002],
        [w*.65,h*.35,220,60, 80, t*.0015+1],
        [w*.85,h*.55, 60,200,180,t*.0025+2],
      ];
      neons.forEach(([cx,cy,r,g,b,phase]) => {
        const p = .08 + .04*Math.sin(phase);
        const ng = ctx.createRadialGradient(cx,cy,0, cx,cy,h*.55);
        ng.addColorStop(0,`rgba(${r},${g},${b},${p})`);
        ng.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=ng; ctx.fillRect(0,0,w,h);
      });
      ctx.globalAlpha=.1;
      for (let i=0;i<8;i++){
        const rx=(i*17)%w, ry=((t*.07+i*29)%(h+20))-10;
        ctx.strokeStyle='rgba(80,120,200,1)';ctx.lineWidth=.5;
        ctx.beginPath(); ctx.moveTo(rx,ry); ctx.lineTo(rx,ry+11); ctx.stroke();
      }
      ctx.globalAlpha=1;
    },
    branch(ctx, w, h, t) {
      ctx.fillStyle = '#080806'; ctx.fillRect(0,0,w,h);
      const fog = ctx.createLinearGradient(0,h*.5,0,h);
      fog.addColorStop(0,'rgba(90,85,68,0)');
      fog.addColorStop(1,'rgba(70,65,50,.07)');
      ctx.fillStyle=fog; ctx.fillRect(0,0,w,h);
      const sw = Math.sin(t*.0007)*3.5;
      ctx.strokeStyle='rgba(200,192,168,.32)'; ctx.lineWidth=1; ctx.lineCap='round';
      ctx.beginPath(); ctx.moveTo(w*.5,h);
      ctx.quadraticCurveTo(w*.5+sw, h*.58, w*.4+sw*.5, h*.22); ctx.stroke();
      [[.42,.52,.16,.36],[.44,.4,.72,.26],[.41,.3,.14,.13],[.43,.33,.73,.18]].forEach(([x1,y1,x2,y2])=>{
        ctx.globalAlpha=.22;
        ctx.beginPath(); ctx.moveTo(w*x1+sw*.5,h*y1); ctx.lineTo(w*x2+sw,h*y2); ctx.stroke();
      });
      ctx.globalAlpha=1;
    },
    lantern(ctx, w, h, t) {
      ctx.fillStyle = '#060305'; ctx.fillRect(0,0,w,h);
      const fl = .72 + .28*Math.sin(t*.016)*Math.sin(t*.024);
      const lg = ctx.createRadialGradient(w*.5,h*.37,0, w*.5,h*.37,h*.36);
      lg.addColorStop(0,`rgba(220,48,28,${.38*fl})`);
      lg.addColorStop(.45,`rgba(175,28,18,${.12*fl})`);
      lg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=lg; ctx.fillRect(0,0,w,h);
      const ag = ctx.createRadialGradient(w*.5,h*.37,0, w*.5,h*.37,h*.6);
      ag.addColorStop(0,`rgba(160,24,14,${.07*fl})`);
      ag.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=ag; ctx.fillRect(0,0,w,h);
      ctx.globalAlpha=.65*fl;
      ctx.strokeStyle='rgba(220,75,38,.7)'; ctx.lineWidth=1;
      ctx.strokeRect(w*.38, h*.2, w*.24, h*.3);
      ctx.globalAlpha=1;
    }
  };

  // Brush ink hover
  function animBrush(inkCanvas, dir) {
    const ctx = inkCanvas.getContext('2d');
    const w = inkCanvas.width, h = inkCanvas.height;
    let prog = dir==='in' ? 0 : 1;
    const target = dir==='in' ? 1 : 0;
    let raf;
    function step() {
      prog += (target - prog) * .055;
      if (Math.abs(prog-target) < .004) prog = target;
      ctx.clearRect(0,0,w,h);
      if (prog > .01) {
        const r = Math.max(w,h) * 1.15 * prog;
        const g = ctx.createRadialGradient(w/2,h/2,0, w/2,h/2,r);
        g.addColorStop(0,   'rgba(10,8,6,.55)');
        g.addColorStop(.55, 'rgba(10,8,6,.28)');
        g.addColorStop(.85, 'rgba(10,8,6,.08)');
        g.addColorStop(1,   'rgba(10,8,6,0)');
        ctx.fillStyle=g; ctx.fillRect(0,0,w,h);
      }
      inkCanvas.style.opacity = prog > .01 ? '1' : '0';
      if (Math.abs(prog-target) > .003) raf = requestAnimationFrame(step);
    }
    cancelAnimationFrame(raf); step();
  }

  document.querySelectorAll('.atm-card').forEach(card => {
    const type  = card.dataset.scene;
    const bgC   = card.querySelector('.atm-bg-canvas');
    const inkC  = card.querySelector('.atm-ink-canvas');
    const fn    = SCENES[type];
    if (!bgC || !inkC || !fn) return;

    function sizeC() {
      const s = card.querySelector('.atm-scene');
      [bgC, inkC].forEach(c => { c.width=s.offsetWidth; c.height=s.offsetHeight; });
    }
    sizeC();
    window.addEventListener('resize', sizeC);

    card.addEventListener('mouseenter', () => animBrush(inkC, 'in'));
    card.addEventListener('mouseleave', () => animBrush(inkC, 'out'));

    let raf2, vis=false;
    function loop(ts) {
      if (!vis) return;
      fn(bgC.getContext('2d'), bgC.width, bgC.height, ts);
      raf2 = requestAnimationFrame(loop);
    }
    new IntersectionObserver(entries => {
      vis = entries[0].isIntersecting;
      if (vis) requestAnimationFrame(loop);
      else cancelAnimationFrame(raf2);
    }, { threshold:.1 }).observe(card);
  });
})();
</script>

</body>
</html>