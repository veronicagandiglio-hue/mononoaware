/* Pannello laterale (fixed, slide da destra) */
.map-panel {
  position: fixed;
  top: 50%;
  right: 0;
  transform: translateY(-50%) translateX(100%);
  width: 300px;
  background: var(--ink);
  padding: 40px 34px 44px;
  z-index: 200;
  opacity: 0;
  transition: transform 0.55s cubic-bezier(0.16,1,0.3,1), opacity 0.3s ease;
  pointer-events: none;
}
.map-panel.open {
  transform: translateY(-50%) translateX(0);
  opacity: 1;
  pointer-events: auto;
}

.panel-close {
  position: absolute;
  top: 14px; right: 14px;
  background: none; border: none;
  color: rgba(240,235,226,0.28);
  font-size: 16px;
  cursor: pointer;
  font-family: 'EB Garamond', serif;
  padding: 4px;
  line-height: 1;
  transition: color 0.3s;
}
.panel-close:hover { color: var(--blood); }

.panel-kanji {
  display: block;
  font-family: 'Playfair Display', serif;
  font-size: 30px;
  color: transparent;
  -webkit-text-stroke: 1px rgba(240,235,226,0.14);
  line-height: 1;
  margin-bottom: 10px;
}
.panel-country {
  font-family: 'Playfair Display', serif;
  font-size: clamp(30px, 3vw, 44px);
  font-weight: 900;
  line-height: 0.9;
  color: var(--paper);
  letter-spacing: -0.02em;
  margin-bottom: 18px;
}
.panel-phrase {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 15px;
  line-height: 1.55;
  color: rgba(240,235,226,0.46);
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(240,235,226,0.08);
}
.panel-themes {
  list-style: none;
  margin-bottom: 30px;
  color: rgba(240, 235, 226, 0.46);
}
.panel-themes li {
  font-family: 'EB Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(240,235,226,0.3);
  padding: 9px 0;
  border-bottom: 1px solid rgba(240,235,226,0.05);
  display: flex;
  align-items: center;
  gap: 10px;
}
.panel-themes li::before {
  content: '';
  display: block;
  width: 3px; height: 3px;
  border-radius: 50%;
  background: var(--blood);
  flex-shrink: 0;
  opacity: 0.8;
}
.panel-cta {
  font-family: 'EB Garamond', serif;
  font-size: 11px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--paper);
  text-decoration: none;
  border-bottom: 1px solid rgba(240,235,226,0.16);
  padding-bottom: 3px;
  display: inline-block;
  transition: color 0.3s, border-color 0.3s;
}
